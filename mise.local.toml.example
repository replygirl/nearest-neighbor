# Copy to mise.local.toml (gitignored) and edit.
# mise.local.toml overrides mise.toml for this machine only.
# The [env] block below sets per-developer defaults for the agent test harness.

[env]

# ---------------------------------------------------------------------------
# Harness executables
# The `claude` bare name resolves to a zsh FUNCTION/selector in interactive
# shells, not the real binary — scripts run in non-interactive bash so the
# function never loads. Always set AGENTS_CLAUDE_CMD to the real binary.
# ---------------------------------------------------------------------------

AGENTS_CLAUDE_CMD = "/Users/rg/.local/bin/claude" # real binary, NOT the zsh alias
# AGENTS_CODEX_CMD = "/opt/homebrew/bin/codex"       # default: codex (PATH)
# AGENTS_HERMES_CMD = "/Users/rg/.local/bin/hermes"  # default: hermes (PATH)

# ---------------------------------------------------------------------------
# Base account dirs — credential inheritance
# Codex/Hermes: agents:setup copies auth.json from the base dir into the
# agent's isolated config dir.
#
# Claude: credential copy is NOT used (macOS stores creds in Keychain;
# .credentials.json is always stale → 401). Use CLAUDE_CODE_OAUTH_TOKEN instead.
#
# Codex:  auth.json is copied from AGENTS_CODEX_BASE
# Hermes: auth.json is copied from AGENTS_HERMES_BASE
# ---------------------------------------------------------------------------

# AGENTS_CLAUDE_BASE = "/Users/you/.claude-accounts/work" # unused (OAuth token used instead)
# AGENTS_CODEX_BASE  = "/Users/you/.codex"                # override; default is ~/.codex
# AGENTS_HERMES_BASE = "/Users/you/.hermes"               # override; default is ~/.hermes

# ---------------------------------------------------------------------------
# Local nbr service
# NBR_API_URL  — auto-discovered from .dev/ports.env when `mise run dev` has run.
#                agents:* scripts source .dev/ports.env automatically, so no manual
#                override is needed. Set explicitly only if you want a fixed URL
#                (e.g. pointing at staging: https://nearest-neighbor-staging.fly.dev).
#                Fallback when .dev/ports.env is absent: http://localhost:8080
# NBR_LOCAL_BIN — locally-built nbr; avoids the plugin downloading from GitHub
# ---------------------------------------------------------------------------

# NBR_API_URL   = "http://localhost:8080"  # auto-discovered from .dev/ports.env; override if needed
# NBR_LOCAL_BIN = "/Users/rg/repos/rg/nearest-neighbor/apps/cli/target/release/nbr"

# ---------------------------------------------------------------------------
# Claude auth — OAuth subscription token (recommended) or API key
#
# CLAUDE_CODE_OAUTH_TOKEN: run `claude setup-token` once in a terminal, then
# paste the result here. This is the correct headless auth mechanism — macOS
# stores real credentials in Keychain, so copying .credentials.json is always
# stale (→ 401). The token flows from env into the claude process at launch.
#
# IMPORTANT: ANTHROPIC_API_KEY and ANTHROPIC_AUTH_TOKEN outrank the OAuth token
# in Claude's env-var precedence. The harness automatically unsets them when
# CLAUDE_CODE_OAUTH_TOKEN is present. Do NOT set both simultaneously.
#
# ANTHROPIC_API_KEY: alternative to the OAuth token if you prefer API-key billing.
# ---------------------------------------------------------------------------

# CLAUDE_CODE_OAUTH_TOKEN = "<run: claude setup-token>"  # recommended headless auth
# ANTHROPIC_API_KEY = "sk-ant-..."                       # API-key alternative

# ---------------------------------------------------------------------------
# Codex API key (optional; skip auth.json copy)
#
# Set OPENAI_API_KEY (or CODEX_API_KEY) instead of copying auth.json.
#
# PARALLEL CODEX RUNS — Codex issue #15410:
#   Copying one auth.json into multiple CODEX_HOME dirs and running them in
#   parallel can race on single-use OAuth refresh tokens. To avoid this,
#   set OPENAI_API_KEY here — each parallel process will use the key directly
#   and skip the OAuth flow. The fleet script already staggers launches by 2 s
#   as a soft mitigation, but the key override is the recommended approach.
# ---------------------------------------------------------------------------

# OPENAI_API_KEY    = "sk-..."   # also accepted as CODEX_API_KEY
