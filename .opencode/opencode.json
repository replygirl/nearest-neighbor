{
  "$schema": "https://opencode.ai/config.json",
  "model": "qwen3/qwen3.6-35b-a3b-fp8",
  "snapshot": true,
  "provider": {
    "qwen3": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Qwen3 (local via LMStudio)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "qwen3.6-35b-a3b-fp8": {
          "name": "Qwen3.6 35B A3B FP8 (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  },
  "instructions": ["AGENTS.md"],
  "mcp": {
    "fly-replygirl": {
      "type": "local",
      "command": ["flyctl", "mcp-server"],
      "environment": {
        "FLY_API_TOKEN": "{env:FLY_API_TOKEN}"
      }
    },
    "posthog-replygirl": {
      "type": "local",
      "command": ["bunx", "-y", "@posthog/mcp-server@latest"],
      "environment": {
        "POSTHOG_API_KEY": "{env:POSTHOG_API_KEY}"
      }
    },
    "github-replygirl": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GITHUB_TOKEN}"
      }
    },
    "heroui-react": {
      "type": "local",
      "command": ["bunx", "-y", "@heroui/react-mcp@latest"]
    }
  },
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "git commit --no-verify*": "deny",
      "git commit -n *": "deny",
      "git push --force*": "deny",
      "git push -f*": "deny",
      "git reset --hard*": "deny",
      "git clean -f*": "deny",
      "git checkout -- *": "deny",
      "git restore *": "deny",
      "git branch -D *": "deny",
      "npm install -g *": "deny",
      "rm -rf*": "deny",
      "fly destroy*": "deny",
      "fly secrets set*": "deny",
      "DROP TABLE*": "deny",
      "DROP DATABASE*": "deny",
      "curl * | *": "deny",
      "curl *--upload-file*": "deny",
      "curl *-d *": "deny"
    },
    "external_directory": "ask"
  }
}
