{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|exec",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/scripts/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "${PLUGIN_ROOT}/scripts/on-stop.sh"
          }
        ]
      }
    ]
  }
}
