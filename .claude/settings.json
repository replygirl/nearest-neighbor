      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git add)",
      "Bash(git add *)",
      "Bash(git commit)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git tag *)",
      "Bash(gh *)",
      "Bash(hk *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(jq *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(curl *)",
      "Bash(lsof *)",
      "Bash(ss *)",
      "Bash(netstat *)",
      "Bash(ps *)",
      "Bash(dig *)",
      "Bash(host *)",
      "Bash(nslookup *)",
      "Bash(date)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(id)",
      "Bash(id *)",
      "Bash(uname)",
      "Bash(uname *)",
      "Bash(hostname)",
      "Bash(hostname *)",
      "Bash(df *)",
      "Bash(du *)",
      "Bash(stat *)",
      "Bash(file *)",
      "Bash(realpath *)",
      "Bash(readlink *)",
      "Bash(basename *)",
      "Bash(dirname *)",
      "Bash(tree *)",
      "Bash(cut *)",
      "Bash(tr *)",
      "Bash(column *)",
      "Bash(diff *)",
      "Bash(cmp *)",
      "Bash(comm *)",
      "Bash(nl *)",
      "Bash(od *)",
      "Bash(xxd *)",
      "Bash(git fetch *)",
      "Bash(git rev-parse *)",
      "Bash(git ls-files *)",
      "Bash(git ls-remote *)",
      "Bash(git blame *)",
      "Bash(git shortlog *)",
      "Bash(git describe *)",
      "Bash(git cat-file *)",
      "Bash(git reflog *)",
      "Bash(git for-each-ref *)",
      "Bash(git rev-list *)",
      "Bash(git merge-base *)",
      "Bash(git name-rev *)",
      "Bash(git remote -v)",
      "Bash(git remote show *)",
      "Bash(git remote get-url *)",
      "Bash(git config --get *)",
      "Bash(git config --list)",
      "Bash(git grep *)",
      "Bash(docker build *)",
      "Bash(docker buildx build *)",
      "Bash(docker run *)",
      "Bash(docker create *)",
      "Bash(docker start *)",
      "Bash(docker stop *)",
      "Bash(docker restart *)",
      "Bash(docker kill *)",
      "Bash(docker exec *)",
      "Bash(docker cp *)",
      "Bash(docker ps)",
      "Bash(docker ps *)",
      "Bash(docker images)",
      "Bash(docker images *)",
      "Bash(docker image ls *)",
      "Bash(docker inspect *)",
      "Bash(docker logs *)",
      "Bash(docker top *)",
      "Bash(docker port *)",
      "Bash(docker stats *)",
      "Bash(docker wait *)",
      "Bash(docker diff *)",
      "Bash(docker pull *)",
      "Bash(docker tag *)",
      "Bash(docker save *)",
      "Bash(docker load *)",
      "Bash(docker version)",
      "Bash(docker info)",
      "Bash(docker network ls *)",
      "Bash(docker network create *)",
      "Bash(docker network inspect *)",
      "Bash(docker volume ls *)",
      "Bash(docker volume create *)",
      "Bash(docker volume inspect *)",
      "Bash(docker compose build *)",
      "Bash(docker compose run *)",
      "Bash(docker compose up *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose config *)",
      "Bash(docker compose stop *)",
      "Bash(docker compose restart *)",
      "Bash(docker compose down *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker image prune *)",
      "Bash(docker container prune *)",
      "Bash(docker builder prune *)",
      "Bash(docker buildx prune *)",
      "Bash(docker network rm *)",
      "Bash(docker network prune *)",
      "Read(**)",
      "Glob(**)",
      "Grep(**)"
    ],
    "ask": ["Bash(git push *)", "Bash(docker push *)"],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git commit --no-verify *)",
      "Bash(git commit -n *)",
      "Bash(npm install -g *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.env.local)",
      "Read(**/secrets/**)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-format.sh",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-guard.sh"
          }
        ]
      }
    ]
  }
}
