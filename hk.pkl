amends "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Config.pkl"

// NOTE: Builtins import omitted — pklr (experimental backend, HK_PKL_BACKEND=pklr)
// has deserialization issues with Builtins._type fields. All steps are defined
// explicitly below, which is equivalent and more portable.
//
// NOTE: Multiline check strings (#"""..."""#) inside commit-msg steps cause pklr
// deserialization failures. Complex multi-step logic is delegated to scripts in
// scripts/hooks/ for pklr compatibility.

local tsGlobs    = List("**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.mts", "**/*.cts")
local tomlGlobs  = List("**/*.toml")
local shellGlobs = List("**/*.sh", "**/*.bash")
local rustGlobs  = List("**/*.rs")
local ciGlobs    = List(".github/workflows/**/*.yml", ".github/workflows/**/*.yaml")
local pyGlobs    = List("plugins/hermes/**/*.py")
local pluginGlobs = List("plugins/**", "apps/cli/**", ".claude-plugin/marketplace.json", ".agents/plugins/marketplace.json", "e2e/plugins/**", "e2e/plugin-install/**")

local agentGlobs   = List(".agents/shared.md", "CLAUDE.md", "AGENTS.md")

local agentSteps = new Mapping<String, Step> {

  ["agents:check"] {
    glob  = agentGlobs
    check = "mise run agents:check"
  }

}

// brand-assets: the committed OG image + favicons are generated from the page
// copy (apps/web/app/brand.ts) and palette (apps/web/app/app.css). If either —
// or the generator — changes, fail until `mise run web:brand-assets` is re-run.
// The check renders nothing (no Chromium), so it is fast and cross-platform.
local brandSteps = new Mapping<String, Step> {

  ["brand-assets"] {
    glob  = List("apps/web/app/brand.ts", "apps/web/app/app.css", "apps/web/scripts/generate-brand-assets.ts")
    check = "mise run web:brand-assets:check"
  }

}

local linters = new Mapping<String, Step> {

  ["oxfmt"] {
    glob   = tsGlobs
    check  = "oxfmt --check {{files}}"
    fix    = "oxfmt {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

  ["oxlint"] {
    glob   = tsGlobs
    check  = "oxlint {{files}}"
    fix    = "oxlint --fix {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

  ["taplo"] {
    glob   = tomlGlobs
    check  = "taplo format --check {{files}}"
    fix    = "taplo format {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

  ["shellcheck"] {
    glob    = shellGlobs
    exclude = List("docs/cli/completions/**", "docs/cli/man/**")
    // -x follows `# shellcheck source=` directives so scripts that source a
    // sibling lib (e.g. scripts/mise-tasks/agents/*) lint cleanly standalone.
    check   = "shellcheck -x {{files}}"
    batch   = true
    prefix  = "mise exec --"
  }

  ["actionlint"] {
    glob   = ciGlobs
    check  = "actionlint {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

  ["cargo-fmt"] {
    glob  = rustGlobs
    check = "cargo fmt --manifest-path apps/cli/Cargo.toml -- --check"
    fix   = "cargo fmt --manifest-path apps/cli/Cargo.toml"
  }

  ["ruff-format"] {
    glob   = pyGlobs
    check  = "ruff format --check {{files}}"
    fix    = "ruff format {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

  ["ruff-lint"] {
    glob   = pyGlobs
    check  = "ruff check {{files}}"
    fix    = "ruff check --fix {{files}}"
    batch  = true
    prefix = "mise exec --"
  }

}

local slowSteps = new Mapping<String, Step> {

  ["cargo-clippy"] {
    glob     = rustGlobs
    check    = "NBR_NO_KEYRING=1 cargo clippy --manifest-path apps/cli/Cargo.toml --all-targets -- -D warnings"
    profiles = List("slow")
  }

  ["typecheck"] {
    glob      = tsGlobs
    check     = "tsgo --noEmit"
    profiles  = List("slow")
    exclusive = true
  }

  ["ty"] {
    glob = pyGlobs
    // Source modules only (plugins/hermes/*.py): keeps the package path intact so
    // the relative import resolves and skips tests/ (intentional junk types).
    check    = "ty check plugins/hermes/*.py"
    profiles = List("slow")
    prefix   = "mise exec --"
  }

  ["test"] {
    check     = "bun test --changed"
    profiles  = List("slow")
    exclusive = true
  }

  // secrets-scan: block push if common secret patterns found in the diff being pushed
  // Patterns: PEM private keys, GitHub PATs, AWS credentials, Stripe keys
  // Logic delegated to scripts/hooks/check-secrets for pklr compatibility
  ["secrets-scan"] {
    check    = "bash scripts/hooks/check-secrets"
    profiles = List("slow")
  }

  // plugin-hooks: fast hook-isolation tests (claude/codex shell hooks + install-nbr
  // via bun, hermes via pytest). No Docker, no API keys.
  ["plugin-hooks"] {
    glob     = pluginGlobs
    check    = "mise run test:plugins && mise run test:plugins:hermes"
    profiles = List("slow")
  }

  // plugin-install: in-harness install tests in Docker (claude/codex/hermes).
  // run.sh self-skips cleanly when no Docker daemon is reachable, so contributors
  // without Docker can still push. Heavier (builds nbr from HEAD, pulls images);
  // BuildKit + image caches keep repeat runs fast. Path-gated to plugin/CLI changes.
  ["plugin-install"] {
    glob     = pluginGlobs
    check    = "mise run test:plugins:harness"
    profiles = List("slow")
  }

}

hooks {

  // pre-commit: fix=true runs autofixers on staged files
  // Stash strategy: patch-file avoids git index lock errors
  ["pre-commit"] {
    fix   = true
    stash = "patch-file"
    steps = new {
      ...linters
      ...agentSteps
      ...brandSteps
    }
  }

  // pre-push: check-only; slow profile adds typecheck + tests + secrets-scan
  // Fast (default): lint only
  // Slow (HK_PROFILE=slow): full suite
  // Branch-aware gating: .git/hooks/pre-push is scripts/hooks/pre-push-gate
  // which auto-upgrades to HK_PROFILE=slow on main (production deploys via workflow_dispatch).
  ["pre-push"] {
    steps = new {
      ...linters
      ...slowSteps
      ...brandSteps
    }
  }

  // commit-msg: conventional commits enforcement + scope validation
  // Valid types: feat fix chore docs style refactor test perf ci build revert
  // Valid scopes (must match an app, package, or infra area — or be omitted):
  //   apps:     api | web
  //   packages: db | analytics | api-types
  //   tooling:  cli | claude-plugin | codex-plugin | hermes-plugin
  //   infra, ci, docs, dev, agents, hooks, deps, test, chore
  // Logic delegated to scripts/hooks/check-commit-msg for pklr compatibility
  ["commit-msg"] {
    steps {
      ["conventional"] {
        check = #"bash scripts/hooks/check-commit-msg "{{commit_msg_file}}""#
      }
    }
  }

  // NOTE: post-merge hook is NOT managed by hk (hk 1.41.0 only supports
  // pre-commit, commit-msg, pre-push, prepare-commit-msg).
  // The post-merge hook lives at scripts/hooks/post-merge and is installed
  // by `mise run hooks:install` alongside the hk-managed hooks.

}
