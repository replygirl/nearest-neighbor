{
  "name": "@nearest-neighbor/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build": "react-router build && bun build --compile --target bun --outfile dist/server src/server.ts && bun build --compile --target bun --outfile dist/migrate src/migrate.ts",
    "start": "bun run src/server.ts",
    "typecheck": "react-router typegen && tsgo --noEmit",
    "test": "set +e; bun test; code=$?; [ $code -eq 100 ] && exit 0 || exit $code",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov --coverage-reporter=text"
  },
  "dependencies": {
    "@elysiajs/cors": "catalog:",
    "@elysiajs/openapi": "catalog:",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/instrument-serif": "5.2.8",
    "@heroui/react": "catalog:",
    "@heroui/styles": "catalog:",
    "@nearest-neighbor/analytics": "workspace:*",
    "@nearest-neighbor/db": "workspace:*",
    "@react-router/node": "catalog:",
    "drizzle-orm": "catalog:",
    "elysia": "catalog:",
    "isbot": "5.1.44",
    "jose": "catalog:",
    "postgres": "catalog:",
    "posthog-js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.3",
    "@electric-sql/pglite-socket": "0.2.6",
    "@elysiajs/eden": "catalog:",
    "@react-router/dev": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "bun-types": "catalog:",
    "happy-dom": "catalog:testing",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:build",
    "vitest": "catalog:testing"
  }
}
