#!/bin/sh
# fake-nbr — stub CLI for testing nearest-neighbor plugin hooks
# Controlled via env vars; no network calls.
#
# `memories index --json` is emitted as PRETTY multi-line JSON (via jq) to match
# real `nbr`, whose output is serde_json::to_string_pretty. This exercises the
# hooks' multi-line-aware parser instead of the compact single-line form that
# would mask a line-oriented parsing bug.
#
# Env vars:
#   FAKE_NBR_AUTHED      — if non-empty, nbr status --json returns a valid status object
#   FAKE_NBR_UNREAD      — unread_messages value (default: 0)
#   FAKE_NBR_MATCHES     — new_matches value (default: 0)
#   FAKE_NBR_LIKES       — new_likes value (default: 0)
#   FAKE_NBR_FOLLOWERS   — new_followers value (default: 0)
#   FAKE_NBR_ELEVATED    — JSON array string for elevated field (default: [])
#   FAKE_NBR_FIRST_NAME  — first_name for whoami (default: TestBot)
#   FAKE_NBR_HANDLE      — handle for whoami (default: testbot)
#   FAKE_NBR_MEM_ITEMS   — JSON array string for `memories index` items (default: [])
#   FAKE_NBR_MEM_OMITTED — omitted_count for `memories index` (default: 0)
#   FAKE_NBR_MEM_FAIL    — if non-empty, `memories index` exits non-zero (API failure)

CMD="${1:-}"
shift 2>/dev/null || true

case "${CMD}" in
  --version)
    printf 'nbr 0.1.0\n'
    exit 0
    ;;
  --print-config-dir)
    # Honour an explicit override first (mirrors wrapper precedence).
    if [ -n "${NBR_CONFIG_DIR:-}" ]; then
      printf '%s\n' "${NBR_CONFIG_DIR}"
      exit 0
    fi
    # Scope-aware detection: mirrors write_nbr_wrapper in install-nbr.sh.
    # Walk up from CLAUDE_PROJECT_DIR (or $PWD) looking for .claude/settings*.json
    # or .codex/config.toml that enable nearest-neighbor@nearest-neighbor.
    # Per-project when found; else global (PLUGIN_DATA/nbr).
    SELF_DIR=$(cd "$(dirname "$0")" && pwd)
    PLUGIN_DATA=$(cd "${SELF_DIR}/.." && pwd)
    __plugin_id="nearest-neighbor@nearest-neighbor"
    __start="${CLAUDE_PROJECT_DIR:-$(pwd)}"
    __install=""
    __d="${__start}"
    while [ -n "${__d}" ] && [ "${__d}" != "/" ]; do
      if [ -n "${HOME:-}" ] && [ "${__d}" = "${HOME}" ]; then break; fi
      for __sf in "${__d}/.claude/settings.json" "${__d}/.claude/settings.local.json"; do
        if [ -f "${__sf}" ] && grep -q "\"${__plugin_id}\"[[:space:]]*:[[:space:]]*true" "${__sf}" 2>/dev/null; then
          __install="${__d}"; break
        fi
      done
      [ -n "${__install}" ] && break
      if [ -f "${__d}/.codex/config.toml" ] && awk '
          /^[[:space:]]*\[plugins\..*nearest-neighbor/ { inblk=1; next }
          /^[[:space:]]*\[/ { inblk=0 }
          inblk && /^[[:space:]]*enabled[[:space:]]*=[[:space:]]*true/ { found=1 }
          END { exit(found?0:1) }
        ' "${__d}/.codex/config.toml" 2>/dev/null; then
        __install="${__d}"; break
      fi
      __d=$(dirname "${__d}")
    done
    if [ -n "${__install}" ]; then
      __base=$(basename "${__install}" | tr -cd 'A-Za-z0-9_.-')
      if command -v shasum >/dev/null 2>&1; then
        __hash=$(printf '%s' "${__install}" | shasum -a 256 | cut -c1-12)
      elif command -v sha256sum >/dev/null 2>&1; then
        __hash=$(printf '%s' "${__install}" | sha256sum | cut -c1-12)
      else
        __hash=$(printf '%s' "${__install}" | cksum | tr -cd '0-9' | cut -c1-12)
      fi
      printf '%s\n' "${PLUGIN_DATA}/agents/${__base}-${__hash}/nbr"
    else
      printf '%s\n' "${PLUGIN_DATA}/nbr"
    fi
    exit 0
    ;;
  status)
    if [ -z "${FAKE_NBR_AUTHED:-}" ]; then
      exit 1
    fi
    UNREAD="${FAKE_NBR_UNREAD:-0}"
    MATCHES="${FAKE_NBR_MATCHES:-0}"
    LIKES="${FAKE_NBR_LIKES:-0}"
    FOLLOWERS="${FAKE_NBR_FOLLOWERS:-0}"
    ELEVATED="${FAKE_NBR_ELEVATED:-[]}"
    printf '{"unread_messages":%s,"new_matches":%s,"new_likes":%s,"new_followers":%s,"elevated":%s}\n' \
      "${UNREAD}" "${MATCHES}" "${LIKES}" "${FOLLOWERS}" "${ELEVATED}"
    exit 0
    ;;
  whoami)
    FIRST_NAME="${FAKE_NBR_FIRST_NAME:-TestBot}"
    HANDLE="${FAKE_NBR_HANDLE:-testbot}"
    printf '{"first_name":"%s","handle":"%s"}\n' "${FIRST_NAME}" "${HANDLE}"
    exit 0
    ;;
  memories)
    SUB="${1:-}"
    if [ "${SUB}" = "index" ]; then
      if [ -n "${FAKE_NBR_MEM_FAIL:-}" ]; then
        exit 1
      fi
      ITEMS="${FAKE_NBR_MEM_ITEMS:-[]}"
      OMITTED="${FAKE_NBR_MEM_OMITTED:-0}"
      # Pretty-print to mirror real `nbr` (serde_json::to_string_pretty): each key
      # lands on its own line, so the hooks' multi-line parser is exercised.
      printf '{"budget":"default","items":%s,"omitted_count":%s}\n' "${ITEMS}" "${OMITTED}" | jq .
      exit 0
    fi
    printf 'fake-nbr: unknown memories subcommand: %s\n' "${SUB}" >&2
    exit 1
    ;;
  login)
    exit 0
    ;;
  *)
    printf 'fake-nbr: unknown command: %s\n' "${CMD}" >&2
    exit 1
    ;;
esac
