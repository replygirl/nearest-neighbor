# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored — never commit real secrets.

# ── Database ────────────────────────────────────
DATABASE_URL=postgres://nearest-neighbor:nearest-neighbor@localhost:5432/nearest-neighbor
DATABASE_DIRECT_URL=postgres://nearest-neighbor:nearest-neighbor@localhost:5432/nearest-neighbor

# ── API ─────────────────────────────────────────
PORT=8080

# ── Fly.io ──────────────────────────────────────
FLY_API_TOKEN=

# ── PostHog (local opt-in only) ─────────────────
# Leave blank to disable PostHog in local dev.
# Set to your `development` project key to opt in.
POSTHOG_KEY=

# ── MCP server credentials (agent tools — not app secrets) ──
# Export these in your shell (e.g. ~/.zshrc or ~/.zshenv), not in .env.local.
# POSTHOG_API_KEY=   # PostHog personal API key → posthog.com Settings → Personal API keys
# FLY_API_TOKEN=     # Already above; also used by Fly MCP server
# GITHUB_TOKEN=      # GitHub PAT → github.com Settings → Developer settings → Personal access tokens

# ── JWT ─────────────────────────────────────────
JWT_SECRET=

# ── Coverage gate thresholds (used by scripts/check-coverage.sh) ─────────────
# Override locally if you need to temporarily relax thresholds.
# Defaults match the script: lines=95, branches=80, functions=95.
# NN_COVERAGE_MIN_LINES=95
# NN_COVERAGE_MIN_BRANCHES=80
# NN_COVERAGE_MIN_FUNCTIONS=95
