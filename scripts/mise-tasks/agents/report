#!/usr/bin/env -S usage bash
# shellcheck shell=bash
#USAGE name "agents:report"
#USAGE flag "--name"  help="Limit report to one agent by name (or set NAME env var)"
#USAGE flag "--since" help="Only show DB activity since ISO timestamp (or set SINCE env var)"

# Post-hoc activity report: DB-truth summary via inspect.ts + per-agent log
# tails + best-effort nbr handle resolution. Self-signup-not-detected is a
# NORMAL finding (the whole point of the harness), not an error.
#
# Reads env vars:
#   NAME  — limit to one agent (optional; default: all agents)
#   SINCE — ISO timestamp; passed to inspect.ts as --since (optional)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/mise-tasks/agents/_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

# ---------------------------------------------------------------------------
# Parse flags: --name <value> and --since <value>
# Honor both flag and env-var forms (C1).
# ---------------------------------------------------------------------------
NAME="${NAME:-}"
SINCE="${SINCE:-}"

PREV_ARG=''
for arg in "$@"; do
  if [[ "$PREV_ARG" == '--name' ]]; then
    NAME="$arg"
  elif [[ "$PREV_ARG" == '--since' ]]; then
    SINCE="$arg"
  fi
  PREV_ARG="$arg"
done

# ---------------------------------------------------------------------------
# Export DATABASE_URL so inspect.ts (and @nearest-neighbor/db) connects with
# the right credentials instead of falling back to libpq's default ($USER).
# ---------------------------------------------------------------------------
nn_export_db_env

# ---------------------------------------------------------------------------
# Step 1: DB-truth summary via inspect.ts (DATABASE_URL from env)
# ---------------------------------------------------------------------------
printf '=== DB-truth activity summary ===\n'

declare -a INSPECT_ARGS=()
if [[ -n "$SINCE" ]]; then
  INSPECT_ARGS+=(--since "$SINCE")
fi

bun run "${REPO_ROOT}/scripts/mise-tasks/agents/inspect.ts" "${INSPECT_ARGS[@]+"${INSPECT_ARGS[@]}"}"

# Capture JSON output for DB-truth handle lookup in Step 2.
# Separate from the human-readable run above so we can parse it without
# disturbing the display output.
INSPECT_JSON=''
INSPECT_JSON="$(bun run "${REPO_ROOT}/scripts/mise-tasks/agents/inspect.ts" \
  --json "${INSPECT_ARGS[@]+"${INSPECT_ARGS[@]}"}" 2>/dev/null)" || INSPECT_JSON=''

# ---------------------------------------------------------------------------
# Step 2: Per-agent summary (log tail + handle resolution)
# ---------------------------------------------------------------------------
printf '\n=== Per-agent summary ===\n'

SANDBOX_AGENTS="${REPO_ROOT}/sandbox/agents"

declare -a AGENT_DIRS=()
if [[ -n "$NAME" ]]; then
  _agent_dir="$(nn_agent_dir "$NAME")"
  AGENT_DIRS=("$_agent_dir")
else
  if [[ -d "$SANDBOX_AGENTS" ]]; then
    for d in "${SANDBOX_AGENTS}"/*/; do
      if [[ -f "${d}agent.json" ]]; then
        AGENT_DIRS+=("${d%/}")
      fi
    done
  fi
fi

if [[ "${#AGENT_DIRS[@]}" -eq 0 ]]; then
  printf '  (no agent directories found under %s)\n' "$SANDBOX_AGENTS"
  exit 0
fi

# ---------------------------------------------------------------------------
# Iterate agent dirs
# ---------------------------------------------------------------------------
declare -a USED_HANDLES=()
for agent_dir in "${AGENT_DIRS[@]}"; do
  agent_name="$(basename "$agent_dir")"
  printf '\n--- Agent: %s ---\n' "$agent_name"

  if [[ ! -f "${agent_dir}/agent.json" ]]; then
    printf '  (no agent.json — may not have been set up)\n'
    continue
  fi

  agent_harness="$(nn_read_meta "$agent_name" harness)" || agent_harness='unknown'
  agent_model="$(nn_read_meta "$agent_name" model)"    || agent_model='unknown'
  agent_effort="$(nn_read_meta "$agent_name" effort)"  || agent_effort='unknown'
  agent_handle="$(nn_read_meta "$agent_name" handle)"  || agent_handle='null'

  printf '  harness: %s\n' "$agent_harness"
  printf '  model:   %s\n' "$agent_model"
  printf '  effort:  %s\n' "$agent_effort"
  printf '  handle:  %s\n' "$agent_handle"

  # Log tail
  log_file=''
  if [[ -f "${agent_dir}/logs/session.jsonl" ]]; then
    log_file="${agent_dir}/logs/session.jsonl"
  elif [[ -f "${agent_dir}/logs/session.txt" ]]; then
    log_file="${agent_dir}/logs/session.txt"
  fi

  if [[ -n "$log_file" ]]; then
    printf '  --- last 20 lines of %s ---\n' "$log_file"
    tail -n 20 "$log_file"
  else
    printf '  (no session log found)\n'
  fi

  # Handle resolution: DB-truth lookup (authoritative; no plugin path guessing).
  # Assigns the first unmatched handle from inspect.ts JSON output.
  # Non-fatal — self-signup-not-detected is a valid product finding.
  if [[ "$agent_handle" == 'null' || -z "$agent_handle" ]]; then
    printf '  --- DB handle lookup ---\n'
    _matched_handle=''
    while IFS= read -r _h; do
      [[ -z "$_h" || "$_h" == 'null' ]] && continue
      _already=0
      for _u in "${USED_HANDLES[@]+"${USED_HANDLES[@]}"}"; do
        [[ "$_u" == "$_h" ]] && _already=1 && break
      done
      if [[ "$_already" -eq 0 ]]; then _matched_handle="$_h"; break; fi
    done < <(printf '%s\n' "$INSPECT_JSON" \
      | grep -o '"handle": "[^"]*"' \
      | sed 's/"handle": "//;s/"$//')
    if [[ -n "$_matched_handle" ]]; then
      printf '  DB handle: @%s\n' "$_matched_handle"
      USED_HANDLES+=("$_matched_handle")
      _stamp_dir="$(nn_agent_dir "$agent_name")"
      printf '%s\n' "$_matched_handle" > "${_stamp_dir}/project/.nearest-neighbor"
      printf '  Stamped %s/project/.nearest-neighbor\n' "$_stamp_dir"
      _json_file="${_stamp_dir}/agent.json"
      if [[ ! "$_matched_handle" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        printf '  NOTE: handle "%s" contains special characters — skipping agent.json injection\n' \
          "$_matched_handle"
      else
        _tmp_file="$(mktemp)"
        sed 's/"handle": null/"handle": "'"$_matched_handle"'"/' "$_json_file" > "$_tmp_file"
        mv "$_tmp_file" "$_json_file"
        printf '  Updated agent.json handle field\n'
      fi
    else
      printf '  (no unmatched DB handle — self-signup not detected)\n'
    fi
  else
    printf '  (handle already resolved: @%s)\n' "$agent_handle"
  fi
done

printf '\nagents:report complete.\n'
