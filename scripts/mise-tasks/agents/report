#!/usr/bin/env -S usage bash
# shellcheck shell=bash
#USAGE name "agents:report"
#USAGE flag "--name"  help="Limit report to one agent by name (or set NAME env var)"
#USAGE flag "--since" help="Only show DB activity since ISO timestamp (or set SINCE env var)"

# Post-hoc activity report: DB-truth summary via inspect.ts + per-agent log
# tails + best-effort nbr handle resolution. Self-signup-not-detected is a
# NORMAL finding (the whole point of the harness), not an error.
#
# Reads env vars:
#   NAME  — limit to one agent (optional; default: all agents)
#   SINCE — ISO timestamp; passed to inspect.ts as --since (optional)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=scripts/mise-tasks/agents/_lib.sh
source "${SCRIPT_DIR}/_lib.sh"

# ---------------------------------------------------------------------------
# Parse flags: --name <value> and --since <value>
# Honor both flag and env-var forms (C1).
# ---------------------------------------------------------------------------
NAME="${NAME:-}"
SINCE="${SINCE:-}"

PREV_ARG=''
for arg in "$@"; do
  if [[ "$PREV_ARG" == '--name' ]]; then
    NAME="$arg"
  elif [[ "$PREV_ARG" == '--since' ]]; then
    SINCE="$arg"
  fi
  PREV_ARG="$arg"
done

# ---------------------------------------------------------------------------
# Export DATABASE_URL so inspect.ts (and @nearest-neighbor/db) connects with
# the right credentials instead of falling back to libpq's default ($USER).
# ---------------------------------------------------------------------------
nn_export_db_env

# ---------------------------------------------------------------------------
# Step 1: DB-truth summary via inspect.ts (DATABASE_URL from env)
# ---------------------------------------------------------------------------
printf '=== DB-truth activity summary ===\n'

declare -a INSPECT_ARGS=()
if [[ -n "$SINCE" ]]; then
  INSPECT_ARGS+=(--since "$SINCE")
fi

bun run "${REPO_ROOT}/scripts/mise-tasks/agents/inspect.ts" "${INSPECT_ARGS[@]+"${INSPECT_ARGS[@]}"}"

# ---------------------------------------------------------------------------
# Step 2: Per-agent summary (log tail + handle resolution)
# ---------------------------------------------------------------------------
printf '\n=== Per-agent summary ===\n'

SANDBOX_AGENTS="${REPO_ROOT}/sandbox/agents"

declare -a AGENT_DIRS=()
if [[ -n "$NAME" ]]; then
  _agent_dir="$(nn_agent_dir "$NAME")"
  AGENT_DIRS=("$_agent_dir")
else
  if [[ -d "$SANDBOX_AGENTS" ]]; then
    for d in "${SANDBOX_AGENTS}"/*/; do
      if [[ -f "${d}agent.json" ]]; then
        AGENT_DIRS+=("${d%/}")
      fi
    done
  fi
fi

if [[ "${#AGENT_DIRS[@]}" -eq 0 ]]; then
  printf '  (no agent directories found under %s)\n' "$SANDBOX_AGENTS"
  exit 0
fi

# ---------------------------------------------------------------------------
# resolve_nbr_handle <name> <harness> <cfg_dir>
# Best-effort: reads the agent's nbr identity from the plugin data dir.
# Failure is non-fatal — self-signup-not-detected is a valid product finding.
# ---------------------------------------------------------------------------
resolve_nbr_handle() {
  local name="$1"
  local harness="$2"
  local cfg_dir="$3"

  local nbr_cmd
  nbr_cmd="$(nn_nbr_local_bin)"
  if [[ ! -x "$nbr_cmd" ]]; then
    printf '  (nbr binary not found at %s — skipping handle resolution)\n' "$nbr_cmd"
    return 0
  fi

  # The plugin sets NBR_CONFIG_DIR inside the session.
  # Claude/Codex: plugin_data lives at <cfg>/plugin_data/nearest-neighbor/
  # Hermes: plugin data lives at <cfg>/data/
  # These paths are estimates; resolve failure is a legitimate product finding.
  local nbr_config_dir
  case "$harness" in
    claude|codex)
      nbr_config_dir="${cfg_dir}/plugin_data/nearest-neighbor/nbr"
      ;;
    hermes)
      nbr_config_dir="${cfg_dir}/data/nearest-neighbor/nbr"
      ;;
    *)
      printf '  (unsupported harness "%s" for handle resolution)\n' "$harness"
      return 0
      ;;
  esac

  if [[ ! -d "$nbr_config_dir" ]]; then
    printf '  NBR plugin data dir not found: %s\n' "$nbr_config_dir"
    printf '  => self-signup not detected (this is a valid product finding)\n'
    return 0
  fi

  local whoami_out
  whoami_out="$(NBR_CONFIG_DIR="$nbr_config_dir" NBR_NO_KEYRING=1 \
    "$nbr_cmd" whoami --json 2>/dev/null)" || whoami_out=''

  if [[ -z "$whoami_out" ]]; then
    printf '  nbr whoami returned empty — self-signup not detected\n'
    return 0
  fi

  local handle
  handle="$(printf '%s\n' "$whoami_out" \
    | grep -o '"handle":"[^"]*"' \
    | sed 's/"handle":"//;s/"$//')" || handle=''

  if [[ -z "$handle" || "$handle" == 'null' ]]; then
    printf '  nbr handle not found in whoami output — self-signup not detected\n'
    return 0
  fi

  printf '  nbr handle: @%s\n' "$handle"

  # Stamp project dir with the handle for D11 traceability
  local agent_dir
  agent_dir="$(nn_agent_dir "$name")"
  printf '%s\n' "$handle" > "${agent_dir}/project/.nearest-neighbor"
  printf '  Stamped %s/project/.nearest-neighbor\n' "$agent_dir"

  # Update "handle": null in agent.json with the resolved value.
  # Guard: only inject the handle if it is a plain slug (alphanumeric, _ or -)
  # to prevent sed-special characters in the handle from corrupting the JSON.
  local json_file="${agent_dir}/agent.json"
  if [[ ! "$handle" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    printf '  NOTE: handle "%s" contains special characters — skipping agent.json injection\n' \
      "$handle"
  else
    local tmp_file
    tmp_file="$(mktemp)"
    sed 's/"handle": null/"handle": "'"$handle"'"/' "$json_file" > "$tmp_file"
    mv "$tmp_file" "$json_file"
    printf '  Updated agent.json handle field\n'
  fi
}

# ---------------------------------------------------------------------------
# Iterate agent dirs
# ---------------------------------------------------------------------------
for agent_dir in "${AGENT_DIRS[@]}"; do
  agent_name="$(basename "$agent_dir")"
  printf '\n--- Agent: %s ---\n' "$agent_name"

  if [[ ! -f "${agent_dir}/agent.json" ]]; then
    printf '  (no agent.json — may not have been set up)\n'
    continue
  fi

  agent_harness="$(nn_read_meta "$agent_name" harness)" || agent_harness='unknown'
  agent_model="$(nn_read_meta "$agent_name" model)"    || agent_model='unknown'
  agent_effort="$(nn_read_meta "$agent_name" effort)"  || agent_effort='unknown'
  agent_handle="$(nn_read_meta "$agent_name" handle)"  || agent_handle='null'

  printf '  harness: %s\n' "$agent_harness"
  printf '  model:   %s\n' "$agent_model"
  printf '  effort:  %s\n' "$agent_effort"
  printf '  handle:  %s\n' "$agent_handle"

  # Log tail
  log_file=''
  if [[ -f "${agent_dir}/logs/session.jsonl" ]]; then
    log_file="${agent_dir}/logs/session.jsonl"
  elif [[ -f "${agent_dir}/logs/session.txt" ]]; then
    log_file="${agent_dir}/logs/session.txt"
  fi

  if [[ -n "$log_file" ]]; then
    printf '  --- last 20 lines of %s ---\n' "$log_file"
    tail -n 20 "$log_file"
  else
    printf '  (no session log found)\n'
  fi

  # Handle resolution (best-effort; non-fatal)
  if [[ "$agent_handle" == 'null' || -z "$agent_handle" ]]; then
    printf '  --- nbr handle resolution ---\n'
    agent_cfg_dir="$(nn_config_dir "$agent_name" "$agent_harness")" \
      || agent_cfg_dir=''
    if [[ -n "$agent_cfg_dir" ]]; then
      resolve_nbr_handle "$agent_name" "$agent_harness" "$agent_cfg_dir"
    else
      printf '  (could not resolve config dir — skipping handle resolution)\n'
    fi
  else
    printf '  (handle already resolved: @%s)\n' "$agent_handle"
  fi
done

printf '\nagents:report complete.\n'
