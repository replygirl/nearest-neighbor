#!/usr/bin/env bash
# check-secrets: scan the diff being pushed for common secret patterns
# Called by hk pre-push hook (slow profile only).
# Exit 0 = OK, exit 1 = secret detected (blocks push).

set -euo pipefail

DIFF=$(git diff HEAD~1..HEAD 2>/dev/null || git diff HEAD 2>/dev/null || true)

if [ -z "$DIFF" ]; then
  exit 0
fi

# Patterns scanned:
#   - PEM private keys (RSA, EC, DSA, OpenSSH)
#   - GitHub PATs (ghp_, ghs_, github_pat_)
#   - AWS access key IDs (AKIA...)
#   - AWS secret access keys (assignment form)
#   - Stripe live/test secret keys (sk_live_, sk_test_, rk_live_, rk_test_)

if echo "$DIFF" | grep -qiE \
  '(-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY|ghp_[A-Za-z0-9]{36}|ghs_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{82}|AKIA[0-9A-Z]{16}|sk_(live|test)_[A-Za-z0-9]{24,}|rk_(live|test)_[A-Za-z0-9]{24,}|[Aa][Ww][Ss]_[Ss][Ee][Cc][Rr][Ee][Tt]_[Aa][Cc][Cc][Ee][Ss][Ss]_[Kk][Ee][Yy]\s*=\s*[A-Za-z0-9/+]{40})'; then
  echo "ERROR: potential secret detected in diff. Remove the secret before pushing." >&2
  echo "       If this is a false positive, open an issue to refine the pattern." >&2
  exit 1
fi

exit 0
