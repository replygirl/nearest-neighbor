#!/usr/bin/env bash
# post-checkout — non-blocking environment-freshness check after branch switch
# Installed by: mise run hooks:install
# Always exits 0 (must not block branch switching).
#
# Args (from git):
#   $1  previous HEAD
#   $2  new HEAD
#   $3  flag: 1 = branch checkout, 0 = file checkout

PREV_HEAD="${1:-}"
NEW_HEAD="${2:-}"
CHECKOUT_TYPE="${3:-1}"

# Skip file-only checkouts (e.g. git checkout -- <file>)
if [ "$CHECKOUT_TYPE" = "0" ]; then
  exit 0
fi

# Skip no-op checkouts (hk fires hooks even when HEAD didn't move)
if [ -n "$PREV_HEAD" ] && [ -n "$NEW_HEAD" ] && [ "$PREV_HEAD" = "$NEW_HEAD" ]; then
  exit 0
fi

# Warn if DB migrations may need re-running after the switch
if git diff --name-only "$PREV_HEAD" "$NEW_HEAD" 2>/dev/null | grep -q 'packages/db/migrations/'; then
  echo "[post-checkout] DB migrations changed between branches." >&2
  echo "               Run 'mise run db:migrate' before starting the server." >&2
fi

exit 0
